<html
  lang={Gettext.get_locale(SensoctoWeb.Gettext)}
  dir={if Gettext.get_locale(SensoctoWeb.Gettext) == "ar", do: "rtl", else: "ltr"}
  class="h-full"
  data-theme="dark"
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <%!-- Inline theme detection — runs before CSS to prevent flash --%>
    <script>
      (function() {
        var saved = localStorage.getItem('sensocto-theme');
        var theme = saved || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <.live_title>
      {assigns[:page_title] || "Sensocto"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <!-- Three.js from CDN - required by GaussianSplats3D for 3D object viewer -->
    <!-- Using v0.160.0 which has UMD build exposing global THREE (>=0.160.0 required) -->
    <script src="https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js">
    </script>
    <script defer phx-track-static src={~p"/assets/sparkline_init.js"} type="module">
    </script>
    <script defer phx-track-static src={~p"/assets/app.js"}>
    </script>
    <script>
      window.userSocketToken = "<%= assigns[:user_socket_token] || "" %>";
    </script>
    {Application.get_env(:live_debugger, :live_debugger_tags)}
  </head>

  <body class="h-full text-white font-mono">
    <script>
      // Prevent flash of collapsible panels: hide before first paint based on localStorage
      (function() {
        var panels = [
          ["ui:content_panel_collapsed", "content-panel-body"],
          ["ui:sensor_panel_collapsed", "sensor-panel-body"]
        ];
        var css = "";
        for (var i = 0; i < panels.length; i++) {
          if (localStorage.getItem(panels[i][0]) === "true") {
            css += "#" + panels[i][1] + "{display:none!important}";
          }
        }
        if (css) {
          var s = document.createElement("style");
          s.id = "panel-flash-guard";
          s.textContent = css;
          document.head.appendChild(s);
        }
      })();
    </script>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded"
    >
      Skip to main content
    </a>
    {@inner_content}
  </body>
</html>
