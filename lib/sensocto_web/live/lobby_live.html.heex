<div id="status" class="hidden" phx-disconnected={JS.show()} phx-connected={JS.hide()}>
  Attempting to reconnect...
</div>

<div
  id="lobby-preferences"
  phx-hook="LobbyPreferences"
  class="pb-40 sm:pb-32"
>
  <%!-- Client health monitoring for adaptive streaming --%>
  <div id="client-health-monitor" phx-hook="ClientHealthHook" class="hidden"></div>

  <.breadcrumbs>
    <:crumb>Lobby</:crumb>
  </.breadcrumbs>

  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3 text-xs text-gray-500"></div>
    <div class="flex items-center gap-4">
      <%!-- Guide Session button --%>
      <button
        :if={
          is_nil(@guiding_session) && is_nil(@guided_session) && @current_user &&
            !Map.get(@current_user, :is_guest, false)
        }
        phx-click="start_guided_session"
        class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-purple-600/20 hover:bg-purple-600/40 text-purple-300 hover:text-purple-200 border border-purple-600/30 transition-colors text-xs font-medium"
        title="Start a guided session and invite someone to follow along"
      >
        <Heroicons.icon name="academic-cap" type="outline" class="h-4 w-4" />
        <span class="hidden sm:inline">Guide</span>
      </button>

      <%!-- Layout toggle: stacked ↔ side-by-side --%>
      <div class="flex items-center gap-1.5">
        <span class="text-xs text-gray-500">Layout</span>
        <button
          phx-click="toggle_lobby_layout"
          title={
            if(@lobby_layout == :side_by_side,
              do: "Switch to stacked layout",
              else: "Switch to side-by-side layout"
            )
          }
          class="p-1.5 rounded-lg bg-gray-700/50 hover:bg-gray-600 text-gray-300 hover:text-white transition-colors"
        >
          <Heroicons.icon
            name={if(@lobby_layout == :side_by_side, do: "bars-3", else: "view-columns")}
            type="outline"
            class="h-4 w-4"
          />
        </button>
      </div>

      <%!-- Quality Indicator & Override --%>
      <div class="flex items-center gap-2">
        <span class="text-xs text-gray-500">Data Quality</span>
        <div class={"flex items-center gap-1.5 px-2 py-1 rounded-full text-xs font-medium " <>
          case @current_quality do
            :high -> "bg-green-600/20 text-green-400 border border-green-600/30"
            :medium -> "bg-yellow-600/20 text-yellow-400 border border-yellow-600/30"
            :low -> "bg-orange-600/20 text-orange-400 border border-orange-600/30"
            :minimal -> "bg-red-600/20 text-red-400 border border-red-600/30"
            :paused -> "bg-gray-600/20 text-gray-300 border border-gray-600/30 animate-pulse"
          end}>
          <span class={"w-2 h-2 rounded-full " <>
            case @current_quality do
              :high -> "bg-green-400"
              :medium -> "bg-yellow-400"
              :low -> "bg-orange-400"
              :minimal -> "bg-red-400 animate-pulse"
              :paused -> "bg-gray-400 animate-pulse"
            end}>
          </span>
          <span>{@current_quality |> to_string() |> String.capitalize()}</span>
          <span :if={@data_mode == :digest} class="text-gray-500">(digest)</span>
          <span :if={@quality_override} class="text-gray-500">(manual)</span>
        </div>

        <%!-- Quality Override Dropdown --%>
        <div class="relative group">
          <button
            class="p-1.5 rounded-lg bg-gray-700/50 hover:bg-gray-600 text-gray-300 hover:text-white transition-colors"
            title="Quality settings"
          >
            <Heroicons.icon name="adjustments-horizontal" type="outline" class="h-4 w-4" />
          </button>
          <div class="absolute right-0 top-full mt-1 w-40 bg-gray-800 border border-gray-700 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
            <div class="p-2 text-xs text-gray-300 border-b border-gray-700">
              Data Quality
            </div>
            <button
              phx-click="set_quality_override"
              phx-value-quality="auto"
              class={"w-full px-3 py-2 text-left text-sm hover:bg-gray-700 flex items-center gap-2 " <>
                if(@quality_override == nil, do: "text-blue-400", else: "text-gray-300")}
            >
              <Heroicons.icon name="cpu-chip" type="outline" class="h-4 w-4" /> Auto
              <span :if={@quality_override == nil} class="ml-auto text-blue-400">✓</span>
            </button>
            <button
              phx-click="set_quality_override"
              phx-value-quality="high"
              class={"w-full px-3 py-2 text-left text-sm hover:bg-gray-700 flex items-center gap-2 " <>
                if(@quality_override == :high, do: "text-green-400", else: "text-gray-300")}
            >
              <span class="w-2 h-2 rounded-full bg-green-400"></span>
              High (20Hz)
              <span :if={@quality_override == :high} class="ml-auto text-green-400">✓</span>
            </button>
            <button
              phx-click="set_quality_override"
              phx-value-quality="medium"
              class={"w-full px-3 py-2 text-left text-sm hover:bg-gray-700 flex items-center gap-2 " <>
                if(@quality_override == :medium, do: "text-yellow-400", else: "text-gray-300")}
            >
              <span class="w-2 h-2 rounded-full bg-yellow-400"></span>
              Medium (10Hz)
              <span :if={@quality_override == :medium} class="ml-auto text-yellow-400">✓</span>
            </button>
            <button
              phx-click="set_quality_override"
              phx-value-quality="low"
              class={"w-full px-3 py-2 text-left text-sm hover:bg-gray-700 flex items-center gap-2 " <>
                if(@quality_override == :low, do: "text-orange-400", else: "text-gray-300")}
            >
              <span class="w-2 h-2 rounded-full bg-orange-400"></span>
              Low (1Hz digest)
              <span :if={@quality_override == :low} class="ml-auto text-orange-400">✓</span>
            </button>
            <button
              phx-click="set_quality_override"
              phx-value-quality="minimal"
              class={"w-full px-3 py-2 text-left text-sm hover:bg-gray-700 flex items-center gap-2 " <>
                if(@quality_override == :minimal, do: "text-red-400", else: "text-gray-300")}
            >
              <span class="w-2 h-2 rounded-full bg-red-400"></span>
              Minimal (0.5Hz)
              <span :if={@quality_override == :minimal} class="ml-auto text-red-400">✓</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%!-- ================================================================== --%>
  <%!-- CALL CONTROLS - Always visible, independent of content tabs --%>
  <%!-- ================================================================== --%>
  <div class="mb-4 p-3 bg-gray-800/50 rounded-lg border border-gray-700">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <Heroicons.icon name="phone" type="solid" class="h-5 w-5 text-gray-300" />
        <span class="text-sm text-gray-300 font-medium">Voice/Video Call</span>
      </div>

      <%= if @in_call do %>
        <%!-- In call: show status and controls --%>
        <div class="flex items-center gap-3">
          <div class="flex items-center gap-2 text-sm text-green-400">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            <span>Connected</span>
            <span class="text-gray-500">
              ({map_size(@call_participants) + 1} in call)
            </span>
          </div>

          <%!-- Quick audio/video toggles --%>
          <div class="flex items-center gap-1">
            <button
              phx-click="toggle_call_audio"
              class={"p-2 rounded-lg transition-colors " <> if(@audio_enabled, do: "bg-gray-700 hover:bg-gray-600 text-gray-300", else: "bg-red-600 hover:bg-red-500 text-white")}
              title={if @audio_enabled, do: "Mute microphone", else: "Unmute microphone"}
            >
              <Heroicons.icon
                name={if @audio_enabled, do: "microphone", else: "microphone"}
                type="solid"
                class="h-4 w-4"
              />
            </button>
            <button
              phx-click="toggle_call_video"
              class={"p-2 rounded-lg transition-colors " <> if(@video_enabled, do: "bg-gray-700 hover:bg-gray-600 text-gray-300", else: "bg-red-600 hover:bg-red-500 text-white")}
              title={if @video_enabled, do: "Turn off camera", else: "Turn on camera"}
            >
              <Heroicons.icon name="video-camera" type="solid" class="h-4 w-4" />
            </button>
          </div>

          <%!-- Expand/collapse participants view --%>
          <button
            phx-click="toggle_call_expanded"
            class={"p-2 rounded-lg transition-colors " <> if(@call_expanded, do: "bg-green-600 text-white", else: "bg-gray-700 hover:bg-gray-600 text-gray-300")}
            title={if @call_expanded, do: "Hide participants", else: "Show participants"}
          >
            <Heroicons.icon
              name={if @call_expanded, do: "chevron-up", else: "chevron-down"}
              type="solid"
              class="h-4 w-4"
            />
          </button>

          <button
            phx-click="leave_call"
            class="px-3 py-1.5 rounded-lg text-sm font-medium bg-red-600 hover:bg-red-500 text-white transition-colors"
          >
            Leave
          </button>
        </div>
      <% else %>
        <%!-- Not in call: show join buttons --%>
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-500">Not connected</span>
          <button
            phx-click="quick_join_call"
            phx-value-mode="video"
            class="px-3 py-1.5 rounded-l-lg text-sm font-medium transition-all flex items-center gap-2 bg-green-600 hover:bg-green-500 text-white"
            title="Join with video"
          >
            <Heroicons.icon name="video-camera" type="solid" class="h-4 w-4" /> Join
          </button>
          <button
            phx-click="quick_join_call"
            phx-value-mode="audio"
            class="px-2 py-1.5 rounded-r-lg text-sm font-medium transition-all flex items-center bg-green-700 hover:bg-green-600 text-white border-l border-green-800"
            title="Join with voice only"
          >
            <Heroicons.icon name="microphone" type="solid" class="h-4 w-4" />
          </button>
        </div>
      <% end %>
    </div>

    <%!-- Expandable video participants grid (inside call controls) --%>
    <div :if={@in_call && @call_expanded} class="mt-4 pt-4 border-t border-gray-700">
      <.live_component
        module={SensoctoWeb.Live.Calls.CallContainerComponent}
        id="lobby-call-container"
        room={%{id: :lobby, name: "Lobby", calls_enabled: true}}
        user={@current_user}
        in_call={@in_call}
        participants={@call_participants}
        external_hook={true}
      />
    </div>
  </div>

  <%!-- ================================================================== --%>
  <%!-- CONTENT TABS + SENSOR LENSES — toggleable side-by-side layout --%>
  <%!-- ================================================================== --%>
  <div class={[
    "flex",
    if(@lobby_layout == :side_by_side, do: "flex-row gap-6 items-start", else: "flex-col")
  ]}>
    <%!-- Left column: Media / 3D / Whiteboard / Polls --%>
    <div class={if(@lobby_layout == :side_by_side, do: "flex-1 min-w-0", else: "")}>
      <div class="flex items-center justify-center gap-1.5 mb-3">
        <button
          phx-click="switch_lobby_mode"
          phx-value-mode="media"
          class={"px-2.5 py-1 rounded text-xs font-medium transition-all flex items-center gap-1.5 " <>
        if(@lobby_mode == :media, do: "bg-blue-600 text-white", else: "bg-gray-700 text-gray-300 hover:bg-gray-600") <>
        if(@media_bump, do: " animate-bump ring-1 ring-blue-300/50", else: "")}
        >
          <Heroicons.icon name="play" type="solid" class="h-3 w-3" /> Media
          <span :if={@media_viewers > 0} class="px-1 py-0.5 text-[10px] rounded-full bg-white/20">
            {@media_viewers}
          </span>
        </button>

        <button
          phx-click="switch_lobby_mode"
          phx-value-mode="object3d"
          class={"px-2.5 py-1 rounded text-xs font-medium transition-all flex items-center gap-1.5 " <>
        if(@lobby_mode == :object3d, do: "bg-cyan-600 text-white", else: "bg-gray-700 text-gray-300 hover:bg-gray-600") <>
        if(@object3d_bump, do: " animate-bump ring-1 ring-cyan-300/50", else: "")}
        >
          <Heroicons.icon name="cube-transparent" type="solid" class="h-3 w-3" /> 3D Object
          <span
            :if={@object3d_viewers > 0}
            class="px-1 py-0.5 text-[10px] rounded-full bg-white/20"
          >
            {@object3d_viewers}
          </span>
        </button>

        <button
          phx-click="switch_lobby_mode"
          phx-value-mode="whiteboard"
          class={"px-2.5 py-1 rounded text-xs font-medium transition-all flex items-center gap-1.5 " <>
        if(@lobby_mode == :whiteboard, do: "bg-green-600 text-white", else: "bg-gray-700 text-gray-300 hover:bg-gray-600") <>
        if(@whiteboard_bump, do: " animate-bump ring-1 ring-green-300/50", else: "")}
        >
          <Heroicons.icon name="pencil-square" type="solid" class="h-3 w-3" /> Whiteboard
          <span
            :if={@whiteboard_viewers > 0}
            class="px-1 py-0.5 text-[10px] rounded-full bg-white/20"
          >
            {@whiteboard_viewers}
          </span>
        </button>

        <button
          phx-click="switch_lobby_mode"
          phx-value-mode="polls"
          class={"px-2.5 py-1 rounded text-xs font-medium transition-all flex items-center gap-1.5 " <>
        if(@lobby_mode == :polls, do: "bg-purple-600 text-white", else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
        >
          <Heroicons.icon name="chart-bar-square" type="solid" class="h-3 w-3" /> Polls
        </button>

        <%!-- Sync Status Indicator --%>
        <.live_component
          module={SensoctoWeb.Live.Components.SyncStatusComponent}
          id="lobby-sync-status"
          synced_users={@synced_users}
          solo_users={@solo_users}
          controller_user_id={@media_controller_user_id}
          current_user={@current_user}
        />
      </div>

      <%!-- Persistent Call Hook Container - ALWAYS mounted to handle join_call events --%>
      <div
        id="call-hook-persistent"
        phx-hook="CallHook"
        data-room-id="lobby"
        data-user-id={@current_user.id}
        data-user-name={
          Map.get(@current_user, :email) || Map.get(@current_user, :display_name) |> to_string()
        }
        data-in-call={to_string(@in_call)}
        class="hidden"
      >
      </div>

      <%!-- Media Player Panel --%>
      <div :if={@lobby_mode == :media} class="mb-6">
        <.live_component
          module={SensoctoWeb.Live.Components.MediaPlayerComponent}
          id="lobby-media-player"
          is_lobby={true}
          current_user={@current_user}
          can_manage={true}
          sync_mode={@sync_mode}
        />
      </div>

      <%!-- 3D Object Viewer Panel --%>
      <div :if={@lobby_mode == :object3d} class="mb-6">
        <.live_component
          module={SensoctoWeb.Live.Components.Object3DPlayerComponent}
          id="lobby-object3d-player"
          is_lobby={true}
          current_user={@current_user}
          can_manage={true}
          sync_mode={@sync_mode}
          socket_id={@socket_id}
        />
      </div>

      <%!-- Whiteboard Panel --%>
      <div :if={@lobby_mode == :whiteboard} class="mb-6">
        <.live_component
          module={SensoctoWeb.Live.Components.WhiteboardComponent}
          id="lobby-whiteboard"
          is_lobby={true}
          current_user={@current_user}
          can_manage={true}
          sync_mode={@sync_mode}
        />
      </div>

      <%!-- Polls Panel --%>
      <div :if={@lobby_mode == :polls} class="mb-6">
        <.live_component
          module={SensoctoWeb.Components.PollsPanelComponent}
          id="lobby-polls-panel"
          current_user={@current_user}
        />
      </div>
    </div>
    <%!-- Right column: Sensor lenses --%>
    <div class={if(@lobby_layout == :side_by_side, do: "flex-1 min-w-0", else: "")}>
      <%!-- Lens Selector - styled like rooms --%>
      <div class="flex items-center mb-2">
        <div class="flex flex-col sm:flex-row sm:items-center gap-3">
          <%!-- Quick lens chips - only show lenses with actual sensor data --%>
          <nav
            aria-label="Lobby view modes"
            class="flex flex-wrap items-center gap-2"
            role="tablist"
          >
            <.link
              patch={~p"/lobby"}
              role="tab"
              aria-selected={to_string(@live_action == :sensors)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :sensors,
              do: "bg-orange text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="squares-2x2" type="outline" class="h-3 w-3" /> All
            </.link>
            <.link
              patch={~p"/lobby/users"}
              role="tab"
              aria-selected={to_string(@live_action == :users)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :users,
              do: "bg-orange text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="users" type="outline" class="h-3 w-3" /> By Person
            </.link>
            <.link
              patch={~p"/lobby/hierarchy"}
              role="tab"
              aria-selected={to_string(@live_action == :hierarchy)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :hierarchy,
              do: "bg-purple-500 text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="rectangle-group" type="outline" class="h-3 w-3" /> Hierarchy
            </.link>
            <.link
              :if={@favorite_sensors != []}
              patch={~p"/lobby/favorites"}
              role="tab"
              aria-selected={to_string(@live_action == :favorites)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :favorites,
              do: "bg-yellow-500 text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="star" type="solid" class="h-3 w-3" /> Favorites
            </.link>
            <.link
              :if={:heartrate in @available_lenses}
              patch={~p"/lobby/heartrate"}
              role="tab"
              aria-selected={to_string(@live_action == :heartrate)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :heartrate,
              do: "bg-orange text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="heart" type="outline" class="h-3 w-3" /> Heartrate
            </.link>
            <.link
              :if={:ecg in @available_lenses}
              patch={~p"/lobby/ecg"}
              role="tab"
              aria-selected={to_string(@live_action == :ecg)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :ecg,
              do: "bg-orange text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="chart-bar" type="outline" class="h-3 w-3" /> ECG
            </.link>
            <.link
              :if={:battery in @available_lenses}
              patch={~p"/lobby/battery"}
              role="tab"
              aria-selected={to_string(@live_action == :battery)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :battery,
              do: "bg-orange text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="battery-50" type="outline" class="h-3 w-3" /> Battery
            </.link>
            <.link
              :if={:imu in @available_lenses}
              patch={~p"/lobby/imu"}
              role="tab"
              aria-selected={to_string(@live_action == :imu)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :imu,
              do: "bg-orange text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="cube" type="outline" class="h-3 w-3" /> IMU
            </.link>
            <.link
              :if={:location in @available_lenses}
              patch={~p"/lobby/location"}
              role="tab"
              aria-selected={to_string(@live_action == :location)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :location,
              do: "bg-orange text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="map-pin" type="outline" class="h-3 w-3" /> Location
            </.link>
            <.link
              :if={:skeleton in @available_lenses}
              patch={~p"/lobby/skeleton"}
              role="tab"
              aria-selected={to_string(@live_action == :skeleton)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :skeleton,
              do: "bg-purple-500 text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="user" type="outline" class="h-3 w-3" /> Skeleton
            </.link>
            <.link
              :if={:respiration in @available_lenses}
              patch={~p"/lobby/breathing"}
              role="tab"
              aria-selected={to_string(@live_action == :respiration)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :respiration,
              do: "bg-cyan-500 text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="signal" type="outline" class="h-3 w-3" /> Breathing
            </.link>
            <.link
              :if={:hrv in @available_lenses}
              patch={~p"/lobby/hrv"}
              role="tab"
              aria-selected={to_string(@live_action == :hrv)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :hrv,
              do: "bg-cyan-500 text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="chart-bar-square" type="outline" class="h-3 w-3" /> HRV
            </.link>
            <.link
              :if={:gaze in @available_lenses}
              patch={~p"/lobby/gaze"}
              role="tab"
              aria-selected={to_string(@live_action == :gaze)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :gaze,
              do: "bg-cyan-500 text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="eye" type="outline" class="h-3 w-3" /> Gaze
            </.link>
            <.link
              patch={~p"/lobby/graph"}
              role="tab"
              aria-selected={to_string(@live_action == :graph)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :graph,
              do: "bg-cyan-500 text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="share" type="outline" class="h-3 w-3" /> Graph
            </.link>
            <.link
              patch={~p"/lobby/graph3d"}
              role="tab"
              aria-selected={to_string(@live_action == :graph3d)}
              class={"px-2 py-1 text-xs rounded-full transition-colors flex items-center gap-1 " <>
            if(@live_action == :graph3d,
              do: "bg-blue-500 text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              <Heroicons.icon name="cube-transparent" type="outline" class="h-3 w-3" /> 3D Graph
            </.link>
          </nav>

          <%!-- Sort Controls — only relevant for sensor list views --%>
          <div
            :if={@live_action in [:sensors, :users, :favorites]}
            class="flex items-center gap-1.5 ml-4"
          >
            <span class="text-xs text-gray-500 mr-1">Sort:</span>
            <button
              phx-click="set_sort"
              phx-value-sort="activity"
              class={"px-2 py-0.5 text-xs rounded-full transition-colors " <>
            if(@sort_by == :activity,
              do: "bg-orange text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              Activity
            </button>
            <button
              phx-click="set_sort"
              phx-value-sort="name"
              class={"px-2 py-0.5 text-xs rounded-full transition-colors " <>
            if(@sort_by == :name,
              do: "bg-orange text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              Name
            </button>
            <button
              phx-click="set_sort"
              phx-value-sort="type"
              class={"px-2 py-0.5 text-xs rounded-full transition-colors " <>
            if(@sort_by == :type,
              do: "bg-orange text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              Type
            </button>
            <button
              :if={:battery in @available_lenses}
              phx-click="set_sort"
              phx-value-sort="battery"
              class={"px-2 py-0.5 text-xs rounded-full transition-colors " <>
            if(@sort_by == :battery,
              do: "bg-orange text-white",
              else: "bg-gray-700 text-gray-300 hover:bg-gray-600")}
            >
              Battery
            </button>
          </div>
        </div>
      </div>

      <div :if={@live_action == :sensors}>
        <%!-- Virtual scroll sensor grid --%>
        <% {rows_before, visible_sensor_ids, rows_after, sensors_remaining} =
          partition_sensors_for_virtual_scroll(@sensor_ids, @visible_range, @cols) %>

        <div
          id="sensor-virtual-scroll"
          phx-hook="VirtualScrollHook"
          data-total-sensors={length(@sensor_ids)}
          data-row-height={@row_height}
          class={[
            "grid grid-cols-1",
            if(@global_view_mode == :summary,
              do:
                "gap-1.5 sm:gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-6",
              else: "gap-2 sm:gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5"
            )
          ]}
        >
          <%!-- Top spacer for sensors above viewport --%>
          <div
            :if={rows_before > 0}
            id="virtual-scroll-top-spacer"
            style={"height: #{rows_before * @row_height}px"}
            class="col-span-full"
            aria-hidden="true"
          />

          <%!-- Visible sensors - rendered as LiveComponents for efficient virtual scrolling --%>
          <div
            :for={sensor_id <- visible_sensor_ids}
            id={"sensor_container_#{sensor_id}"}
          >
            <.live_component
              module={StatefulSensorComponent}
              id={"sensor_#{sensor_id}"}
              sensor_id={sensor_id}
              sensor={
                Map.get(@sensors, sensor_id, %{
                  sensor_id: sensor_id,
                  sensor_name: sensor_id,
                  sensor_type: "unknown",
                  attributes: %{}
                })
              }
              view_mode={@global_view_mode}
              user_id={@current_user && @current_user.id}
              is_favorite={sensor_id in @favorite_sensors}
            />
          </div>

          <%!-- Bottom spacer for sensors below viewport --%>
          <div
            :if={rows_after > 0}
            id="virtual-scroll-bottom-spacer"
            style={"height: #{rows_after * @row_height}px"}
            class="col-span-full"
            aria-hidden="true"
          />

          <%!-- Scroll/loading indicator - always present so JS can control it --%>
          <div
            id="virtual-scroll-indicator"
            class="col-span-full flex items-center justify-center py-4 text-gray-300"
          >
            <%!-- Loading spinner (shown by JS when loading, or server-rendered during initial load) --%>
            <div class={[
              "loading-spinner flex items-center gap-2",
              if(@virtual_scroll_loading, do: "", else: "hidden")
            ]}>
              <svg
                class="animate-spin h-5 w-5 text-orange-400"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
              >
                <circle
                  class="opacity-25"
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="4"
                >
                </circle>
                <path
                  class="opacity-75"
                  fill="currentColor"
                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                >
                </path>
              </svg>
              <span class="text-sm">Loading sensors...</span>
            </div>
            <%!-- "More below" indicator (shown when there are sensors remaining and not loading) --%>
            <div
              :if={sensors_remaining > 0}
              class={[
                "more-text flex items-center gap-2 text-xs text-gray-500",
                if(@virtual_scroll_loading, do: "hidden", else: "")
              ]}
            >
              <Heroicons.icon name="chevron-down" type="outline" class="h-4 w-4 animate-bounce" />
              <span>
                {sensors_remaining} more sensor{if sensors_remaining > 1, do: "s", else: ""} below
              </span>
            </div>
          </div>
        </div>

        <div
          :if={@sensor_ids == []}
          class="text-center py-12 text-gray-300"
        >
          <Heroicons.icon name="signal-slash" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No sensors connected</p>
          <p class="text-sm mt-2">Connect a sensor using the connectors below</p>
        </div>
      </div>

      <div
        :if={@live_action == :heartrate}
        id="composite-heartrate"
        phx-hook="CompositeMeasurementHandler"
      >
        <.svelte
          name="CompositeHeartrate"
          props={%{sensors: @heartrate_sensors}}
          socket={@socket}
          class="w-full"
        />
        <div :if={@heartrate_sensors == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon name="heart" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No heartrate sensors connected</p>
          <p class="text-sm mt-2">Connect a sensor with heartrate capability</p>
        </div>
      </div>

      <div :if={@live_action == :imu} id="composite-imu" phx-hook="CompositeMeasurementHandler">
        <.svelte
          name="CompositeIMU"
          props={%{sensors: @imu_sensors}}
          socket={@socket}
          class="w-full"
        />
        <div :if={@imu_sensors == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon name="cube" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No IMU sensors connected</p>
          <p class="text-sm mt-2">Connect a sensor with IMU capability</p>
        </div>
      </div>

      <div
        :if={@live_action == :location}
        id="composite-location"
        phx-hook="CompositeMeasurementHandler"
      >
        <.svelte
          name="CompositeMap"
          props={%{positions: @location_sensors}}
          socket={@socket}
          class="w-full h-96"
        />
        <div :if={@location_sensors == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon name="map-pin" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No location sensors connected</p>
          <p class="text-sm mt-2">Connect a sensor with geolocation capability</p>
        </div>
      </div>

      <div :if={@live_action == :ecg} id="composite-ecg" phx-hook="CompositeMeasurementHandler">
        <.svelte
          name="CompositeECG"
          props={%{sensors: @ecg_sensors}}
          socket={@socket}
          class="w-full"
        />
        <div :if={@ecg_sensors == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon name="chart-bar" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No ECG sensors connected</p>
          <p class="text-sm mt-2">Connect a sensor with ECG capability</p>
        </div>
      </div>

      <div
        :if={@live_action == :battery}
        id="composite-battery"
        phx-hook="CompositeMeasurementHandler"
      >
        <.svelte
          name="CompositeBattery"
          props={%{sensors: @battery_sensors}}
          socket={@socket}
          class="w-full"
        />
        <div :if={@battery_sensors == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon name="battery-50" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No battery sensors connected</p>
          <p class="text-sm mt-2">Connect a sensor with battery monitoring</p>
        </div>
      </div>

      <div
        :if={@live_action == :skeleton}
        id="composite-skeleton"
        phx-hook="CompositeMeasurementHandler"
        class="h-[min(70vh,600px)] min-h-[250px]"
      >
        <.svelte
          name="CompositeSkeletons"
          props={%{sensors: @skeleton_sensors}}
          socket={@socket}
          class="w-full h-full"
        />
        <div :if={@skeleton_sensors == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon name="user" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No skeleton/pose sensors connected</p>
          <p class="text-sm mt-2">Connect a sensor with pose detection enabled</p>
        </div>
      </div>

      <%!-- Breathing/Respiration Composite View --%>
      <div
        :if={@live_action == :respiration}
        id="composite-breathing"
        phx-hook="CompositeMeasurementHandler"
        class="h-[min(70vh,600px)] min-h-[250px]"
      >
        <.svelte
          name="CompositeBreathing"
          props={%{sensors: @respiration_sensors}}
          socket={@socket}
          class="w-full h-full"
        />
        <div :if={@respiration_sensors == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon name="signal" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No breathing sensors connected</p>
          <p class="text-sm mt-2">Connect a sensor with respiration/breathing data</p>
        </div>
      </div>

      <%!-- HRV Composite View --%>
      <div
        :if={@live_action == :hrv}
        id="composite-hrv"
        phx-hook="CompositeMeasurementHandler"
        class="h-[min(70vh,600px)] min-h-[250px]"
      >
        <.svelte
          name="CompositeHRV"
          props={%{sensors: @hrv_sensors}}
          socket={@socket}
          class="w-full h-full"
        />
        <div :if={@hrv_sensors == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon name="chart-bar-square" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No HRV sensors connected</p>
          <p class="text-sm mt-2">Connect a sensor with HRV data</p>
        </div>
      </div>

      <%!-- Gaze Composite View --%>
      <div
        :if={@live_action == :gaze}
        id="composite-gaze"
        phx-hook="CompositeMeasurementHandler"
        class="w-full"
      >
        <.svelte
          name="CompositeGaze"
          props={%{sensors: @gaze_sensors}}
          socket={@socket}
          class="w-full"
        />
        <div :if={@gaze_sensors == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon name="eye" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No eye tracking sensors connected</p>
          <p class="text-sm mt-2">Connect a Pupil Neon or similar eye tracker</p>
        </div>
      </div>

      <%!-- Favorites View --%>
      <div :if={@live_action == :favorites}>
        <div :if={@favorite_sensors == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon name="star" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No favorite sensors</p>
          <p class="text-sm mt-2">Click the star icon on any sensor to add it to favorites</p>
        </div>
        <div
          :if={@favorite_sensors != []}
          id="favorites-grid"
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4"
        >
          <div
            :for={sensor_id <- @favorite_sensors}
            :if={sensor_id in @sensor_ids}
            id={"sensor_fav_container_#{sensor_id}"}
          >
            {live_render(@socket, StatefulSensorLive,
              id: "stateful_sensor_fav_#{sensor_id}",
              session: %{
                "parent_pid" => self(),
                "sensor_id" => sensor_id,
                "user_id" => @current_user && @current_user.id,
                "is_favorite" => true
              }
            )}
          </div>
        </div>
      </div>

      <%!-- Users/Connectors Summary View with Video Presence --%>
      <div :if={@live_action == :users}>
        <div :if={@sensors_by_user == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon name="users" type="outline" class="h-12 w-12 mx-auto mb-4" />
          <p class="text-lg">No users connected</p>
          <p class="text-sm mt-2">Connect a sensor to see user summaries</p>
        </div>

        <div
          :if={@sensors_by_user != []}
          class="grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3"
        >
          <%= for user <- @sensors_by_user do %>
            <.live_component
              module={SensoctoWeb.Live.Components.UserVideoCardComponent}
              id={"user-video-card-#{user.connector_id}"}
              user={user}
              in_call={user_in_call?(@call_participants, user.connector_id)}
              video_tier={get_user_video_tier(@call_participants, user.connector_id)}
              speaking={user_speaking?(@call_participants, user.connector_id)}
            />
          <% end %>
        </div>
      </div>

      <%!-- Hierarchy View: User > Connector > Sensor tree --%>
      <div :if={@live_action == :hierarchy} class="p-4 space-y-3">
        <div :if={@sensors_by_user == []} class="text-center py-12 text-gray-300">
          <Heroicons.icon
            name="rectangle-group"
            type="outline"
            class="h-12 w-12 mx-auto mb-4"
          />
          <p class="text-lg">No sensors connected</p>
          <p class="text-sm mt-2">Connect sensors to see the hierarchy</p>
        </div>

        <div :for={user <- @sensors_by_user} class="bg-gray-800 rounded-lg border border-gray-700">
          <details open class="group">
            <summary class="flex items-center gap-3 p-3 cursor-pointer select-none hover:bg-gray-750">
              <Heroicons.icon
                name="chevron-right"
                type="solid"
                class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-90"
              />
              <Heroicons.icon name="user" type="solid" class="h-5 w-5 text-purple-400" />
              <span class="text-white font-medium">{user.connector_name}</span>
              <span class="text-xs text-gray-500">
                {length(user.sensors)} sensor{if length(user.sensors) != 1,
                  do: "s"}
              </span>
            </summary>

            <div class="pl-8 pr-3 pb-3 space-y-2">
              <div
                :for={sensor <- user.sensors}
                class="flex items-center gap-2 p-2 bg-gray-700/50 rounded"
              >
                <div class="w-2 h-2 rounded-full bg-green-500" />
                <span class="text-sm text-gray-300">{sensor.sensor_name}</span>
                <span :if={sensor[:sensor_type]} class="text-xs text-gray-500 ml-auto">
                  {sensor[:sensor_type]}
                </span>
              </div>
            </div>
          </details>
        </div>
      </div>

      <%!-- Graph Visualization --%>
      <div
        :if={@live_action == :graph}
        id="lobby-graph-view"
        phx-hook="CompositeMeasurementHandler"
        class="p-4"
      >
        <.svelte
          name="LobbyGraph"
          props={
            %{
              rooms: [],
              users: @sensors_by_user,
              sensors: enrich_sensors_with_attention(@sensors)
            }
          }
          socket={@socket}
          class="w-full h-[calc(100vh-200px)] min-h-[500px] rounded-lg overflow-hidden"
        />
      </div>

      <%!-- 3D Graph Visualization --%>
      <div
        :if={@live_action == :graph3d}
        id="lobby-graph3d-view"
        phx-hook="CompositeMeasurementHandler"
        class="p-4"
      >
        <.svelte
          name="Composite3DGraph"
          props={
            %{
              rooms: [],
              users: @sensors_by_user,
              sensors: enrich_sensors_with_attention(@sensors)
            }
          }
          socket={@socket}
          class="w-full h-[calc(100vh-200px)] min-h-[500px] rounded-lg overflow-hidden"
        />
      </div>

      <%!-- MIDI Output Panel — shared between graph and graph3d --%>
      <div
        :if={@live_action in [:graph, :graph3d]}
        id="midi-output-wrapper"
        class="px-4"
      >
        <div
          id="midi-output-panel"
          phx-hook="MidiOutputHook"
          phx-update="ignore"
          class="mt-3 px-3 py-2 bg-gray-800/40 rounded-lg border border-gray-700/50 flex items-center justify-center gap-3 flex-wrap text-xs"
        >
          <span id="midi-status-dot" class="w-2 h-2 rounded-full bg-gray-500 flex-shrink-0">
          </span>
          <button
            id="midi-toggle-btn"
            class="px-2 py-1 rounded text-xs font-medium bg-gray-700 hover:bg-gray-600 text-gray-300 transition-colors"
          >
            Audio Off
          </button>
          <select
            id="midi-backend-select"
            class="rounded px-2 py-1 text-xs focus:outline-none"
            style="background: #374151; border: 1px solid #4b5563; color: #d1d5db;"
          >
            <option value="midi">MIDI</option>
            <option value="tone">Synth</option>
            <option value="both">Both</option>
          </select>
          <select
            id="midi-device-select"
            class="bg-gray-700 border border-gray-600 rounded px-2 py-1 text-xs text-gray-300 focus:outline-none focus:border-purple-500 min-w-[140px]"
          >
            <option value="">-- Select MIDI output --</option>
          </select>
          <span style="position:relative;display:inline-block;" id="midi-mode-wrap">
            <button
              id="midi-mode-btn"
              class="px-2 py-1 rounded text-xs font-medium bg-gray-600 text-gray-400 hover:bg-gray-500 transition-colors"
            >
              🌊 Abstract
            </button>
            <span
              id="midi-mode-tooltip"
              style="display:none;position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);width:280px;padding:10px 12px;background:rgba(17,12,34,0.96);border:1px solid rgba(139,92,246,0.35);border-radius:8px;color:#d1d5db;font-size:11px;line-height:1.5;text-align:left;white-space:normal;z-index:50;pointer-events:none;box-shadow:0 4px 20px rgba(0,0,0,0.5);"
            >
              <span id="midi-mode-tooltip-content">
                Click to cycle modes: Abstract → Groovy genres → Local AI.<br />
                <b style="color:#c4b5fd;">Abstract</b>
                — raw sensor data as MIDI CCs &amp; note triggers.<br />
                <b style="color:#c4b5fd;">Groovy</b>
                — musical engine with chords, bass, drums &amp; arps driven by biometrics. 4 genre styles.<br />
                <b style="color:#c4b5fd;">Local AI</b>
                — on-device neural net (Magenta) generates melodies from sensor input. Use ⚙ to set key, chords &amp; creativity.
              </span>
            </span>
            <style>
              #midi-mode-wrap:hover #midi-mode-tooltip { display: block !important; }
            </style>
          </span>
          <button
            id="midi-ai-settings-btn"
            class="hidden px-2.5 py-1.5 rounded text-base hover:bg-gray-600 transition-colors"
            style="color: #c4b5fd;"
            title="AI Settings"
          >
            ⚙
          </button>
          <span
            id="midi-chord-display"
            class="text-pink-400 font-mono text-[10px]"
            style="display:none"
          >
          </span>

          <div
            id="tone-instruments"
            class="hidden w-full flex items-center gap-2 flex-wrap text-[10px]"
          >
            <span style="color: #9ca3af;">Voices:</span>
            <label class="flex items-center gap-1 cursor-pointer" style="color: #d1d5db;">
              <input
                type="checkbox"
                id="tone-mute-bass"
                checked
                class="w-3 h-3 accent-red-400 cursor-pointer"
              />
              <span style="color: #f87171;">Bass</span>
              <select
                id="tone-inst-bass"
                class="rounded px-1 py-0.5 text-[10px]"
                style="background: #1f2937; border: 1px solid #4b5563; color: #d1d5db;"
              >
                <option value="default">Genre</option>
              </select>
            </label>
            <label class="flex items-center gap-1 cursor-pointer" style="color: #d1d5db;">
              <input
                type="checkbox"
                id="tone-mute-pad"
                checked
                class="w-3 h-3 accent-violet-400 cursor-pointer"
              />
              <span style="color: #a78bfa;">Pad</span>
              <select
                id="tone-inst-pad"
                class="rounded px-1 py-0.5 text-[10px]"
                style="background: #1f2937; border: 1px solid #4b5563; color: #d1d5db;"
              >
                <option value="default">Genre</option>
              </select>
            </label>
            <label class="flex items-center gap-1 cursor-pointer" style="color: #d1d5db;">
              <input
                type="checkbox"
                id="tone-mute-lead"
                checked
                class="w-3 h-3 accent-emerald-400 cursor-pointer"
              />
              <span style="color: #34d399;">Lead</span>
              <select
                id="tone-inst-lead"
                class="rounded px-1 py-0.5 text-[10px]"
                style="background: #1f2937; border: 1px solid #4b5563; color: #d1d5db;"
              >
                <option value="default">Genre</option>
              </select>
            </label>
            <label class="flex items-center gap-1 cursor-pointer" style="color: #d1d5db;">
              <input
                type="checkbox"
                id="tone-mute-arp"
                checked
                class="w-3 h-3 accent-sky-400 cursor-pointer"
              />
              <span style="color: #38bdf8;">Arp</span>
              <select
                id="tone-inst-arp"
                class="rounded px-1 py-0.5 text-[10px]"
                style="background: #1f2937; border: 1px solid #4b5563; color: #d1d5db;"
              >
                <option value="default">Genre</option>
              </select>
            </label>
          </div>
          <div id="midi-meters" class="hidden ml-auto flex items-center gap-2.5 flex-wrap">
            <div
              class="midi-meter flex items-center gap-1 cursor-pointer select-none rounded px-1 hover:bg-gray-700/50 transition-colors"
              data-midi-attr="tempo"
              title="Click to toggle — MIDI Clock / Group mean heart rate"
            >
              <span class="text-[10px]" style="color: #f87171;">BPM</span>
              <div class="w-16 h-3 rounded-full overflow-hidden" style="background: #374151;">
                <div
                  id="midi-bar-tempo"
                  class="h-full rounded-full transition-all duration-150"
                  style="width: 0%; background: #ef4444;"
                >
                </div>
              </div>
              <span id="midi-val-tempo" class="w-6 tabular-nums" style="color: #d1d5db;">-</span>
            </div>
            <div
              class="midi-meter flex items-center gap-1 cursor-pointer select-none rounded px-1 hover:bg-gray-700/50 transition-colors"
              data-midi-attr="arousal"
              title="Click to toggle — CC7 Volume / Collective arousal"
            >
              <span class="text-[10px]" style="color: #fbbf24;">ARO</span>
              <div class="w-16 h-3 rounded-full overflow-hidden" style="background: #374151;">
                <div
                  id="midi-bar-arousal"
                  class="h-full rounded-full transition-all duration-150"
                  style="width: 0%; background: #f59e0b;"
                >
                </div>
              </div>
              <span id="midi-val-arousal" class="w-6 tabular-nums" style="color: #d1d5db;">
                0
              </span>
            </div>
            <div
              class="midi-meter flex items-center gap-1 cursor-pointer select-none rounded px-1 hover:bg-gray-700/50 transition-colors"
              data-midi-attr="hrv"
              title="Click to toggle — CC1 Mod Wheel / Group HRV RMSSD"
            >
              <span class="text-[10px]" style="color: #c084fc;">HRV</span>
              <div class="w-16 h-3 rounded-full overflow-hidden" style="background: #374151;">
                <div
                  id="midi-bar-hrv"
                  class="h-full rounded-full transition-all duration-75"
                  style="width: 0%; background: #a855f7;"
                >
                </div>
              </div>
              <span id="midi-val-hrv" class="w-6 tabular-nums" style="color: #d1d5db;">0</span>
            </div>
            <div
              class="midi-meter flex items-center gap-1 cursor-pointer select-none rounded px-1 hover:bg-gray-700/50 transition-colors"
              data-midi-attr="breath"
              title="Click to toggle — CC2 Breath / Group breath phase LFO"
            >
              <span class="text-[10px]" style="color: #22d3ee;">BRE</span>
              <div class="w-16 h-3 rounded-full overflow-hidden" style="background: #374151;">
                <div
                  id="midi-bar-breath"
                  class="h-full rounded-full transition-all duration-75"
                  style="width: 0%; background: #06b6d4;"
                >
                </div>
              </div>
              <span id="midi-val-breath" class="w-6 tabular-nums" style="color: #d1d5db;">0</span>
            </div>
            <div
              class="midi-meter flex items-center gap-1 cursor-pointer select-none rounded px-1 hover:bg-gray-700/50 transition-colors"
              data-midi-attr="bsync"
              title="Click to toggle — CC16 / Breathing sync (Kuramoto R)"
            >
              <span class="text-[10px]" style="color: #2dd4bf;">BSy</span>
              <div class="w-16 h-3 rounded-full overflow-hidden" style="background: #374151;">
                <div
                  id="midi-bar-bsync"
                  class="h-full rounded-full transition-all duration-75"
                  style="width: 0%; background: #14b8a6;"
                >
                </div>
              </div>
              <span id="midi-val-bsync" class="w-6 tabular-nums" style="color: #d1d5db;">0</span>
            </div>
            <div
              class="midi-meter flex items-center gap-1 cursor-pointer select-none rounded px-1 hover:bg-gray-700/50 transition-colors"
              data-midi-attr="hsync"
              title="Click to toggle — CC17 / HRV sync (Kuramoto R)"
            >
              <span class="text-[10px]" style="color: #818cf8;">HSy</span>
              <div class="w-16 h-3 rounded-full overflow-hidden" style="background: #374151;">
                <div
                  id="midi-bar-hsync"
                  class="h-full rounded-full transition-all duration-75"
                  style="width: 0%; background: #6366f1;"
                >
                </div>
              </div>
              <span id="midi-val-hsync" class="w-6 tabular-nums" style="color: #d1d5db;">0</span>
            </div>
            <span
              id="midi-sync-trigger"
              class="text-yellow-400 font-bold opacity-0 transition-opacity duration-500 min-w-[70px]"
            >
            </span>
          </div>
          <%!-- AI Settings Modal (inside phx-update="ignore" zone) --%>
          <div
            id="ai-settings-modal"
            class="hidden fixed inset-0 z-50 flex items-center justify-center"
            style="background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);"
          >
            <div
              class="rounded-xl p-5 w-full max-w-md mx-4 shadow-2xl"
              style="background: #1e1b2e; border: 1px solid #3b3556;"
            >
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-semibold" style="color: #c4b5fd;">AI Music Settings</h3>
                <button
                  id="ai-settings-close"
                  class="text-lg leading-none px-2 py-1 rounded hover:bg-gray-700 transition-colors"
                  style="color: #9ca3af;"
                >
                  &times;
                </button>
              </div>
              <%!-- Chord Progression --%>
              <div class="mb-4">
                <label class="block text-[11px] mb-1.5 font-medium" style="color: #a78bfa;">
                  Chord Progression
                </label>
                <input
                  id="ai-chords-input"
                  type="text"
                  placeholder="e.g. Am7 Dm7 G7 Cmaj7"
                  class="w-full rounded-lg px-3 py-2 text-xs focus:outline-none"
                  style="background: #0f0d1a; border: 1px solid #3b3556; color: #e2e0f0;"
                />
                <div id="ai-chord-presets" class="flex flex-wrap gap-1.5 mt-2">
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="Dm7 G7 Cmaj7 Am7"
                  >
                    Jazz ii-V-I
                  </button>
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="Fmaj7 Em7 Dm7 Cmaj7"
                  >
                    Neo Soul
                  </button>
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="Am Fmaj7 C G"
                  >
                    Lo-fi Chill
                  </button>
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="Cm Fm Abmaj7 G7"
                  >
                    Dark Cinema
                  </button>
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="C7 F7 C7 G7"
                  >
                    Blues
                  </button>
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="Dm7 G7 Cmaj7 A7"
                  >
                    Bossa Nova
                  </button>
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="Cmaj7 Am7 Fmaj7 G"
                  >
                    Dreamy Pop
                  </button>
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="Em Bm C D"
                  >
                    Indie Rock
                  </button>
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="Bbmaj7 Cm7 Fm7 Gm7"
                  >
                    Reggae
                  </button>
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="C F G F"
                  >
                    Ska
                  </button>
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="E A B A"
                  >
                    Punk
                  </button>
                  <button
                    class="ai-preset-btn px-2 py-1 rounded text-[10px] transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-chords="Em G D C"
                  >
                    Grunge
                  </button>
                </div>
              </div>
              <%!-- Key Selector --%>
              <div class="mb-4">
                <label class="block text-[11px] mb-1.5 font-medium" style="color: #a78bfa;">
                  Key
                </label>
                <div class="flex gap-2">
                  <select
                    id="ai-key-root"
                    class="rounded-lg px-3 py-1.5 text-xs flex-1 focus:outline-none"
                    style="background: #0f0d1a; border: 1px solid #3b3556; color: #e2e0f0;"
                  >
                    <option value="0">C</option>
                    <option value="1">C# / Db</option>
                    <option value="2">D</option>
                    <option value="3">Eb</option>
                    <option value="4">E</option>
                    <option value="5">F</option>
                    <option value="6">F# / Gb</option>
                    <option value="7">G</option>
                    <option value="8">Ab</option>
                    <option value="9">A</option>
                    <option value="10">Bb</option>
                    <option value="11">B</option>
                  </select>
                  <select
                    id="ai-key-quality"
                    class="rounded-lg px-3 py-1.5 text-xs flex-1 focus:outline-none"
                    style="background: #0f0d1a; border: 1px solid #3b3556; color: #e2e0f0;"
                  >
                    <option value="major">Major</option>
                    <option value="minor" selected>Minor</option>
                  </select>
                </div>
              </div>
              <%!-- Creativity Slider --%>
              <div class="mb-4">
                <label class="block text-[11px] mb-1.5 font-medium" style="color: #a78bfa;">
                  Creativity
                  <span id="ai-creativity-label" class="font-normal" style="color: #9ca3af;">
                    — Auto (from breathing)
                  </span>
                </label>
                <div class="flex items-center gap-3">
                  <span class="text-[10px]" style="color: #6b7280;">Tight</span>
                  <input
                    id="ai-creativity-slider"
                    type="range"
                    min="0"
                    max="100"
                    value="50"
                    class="flex-1 h-1.5 rounded-full appearance-none cursor-pointer"
                    style="accent-color: #a78bfa; background: #2d2845;"
                  />
                  <span class="text-[10px]" style="color: #6b7280;">Wild</span>
                </div>
                <div class="flex items-center gap-2 mt-1.5">
                  <label
                    class="flex items-center gap-1 text-[10px] cursor-pointer"
                    style="color: #9ca3af;"
                  >
                    <input
                      id="ai-creativity-auto"
                      type="checkbox"
                      checked
                      class="rounded"
                      style="accent-color: #a78bfa;"
                    /> Auto (breathing controls creativity)
                  </label>
                </div>
              </div>
              <%!-- Mood Override --%>
              <div class="mb-5">
                <label class="block text-[11px] mb-1.5 font-medium" style="color: #a78bfa;">
                  Mood
                </label>
                <div class="flex gap-1.5" id="ai-mood-buttons">
                  <button
                    class="ai-mood-btn flex-1 px-2 py-1.5 rounded-lg text-[10px] font-medium transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-mood="auto"
                  >
                    Auto
                  </button>
                  <button
                    class="ai-mood-btn flex-1 px-2 py-1.5 rounded-lg text-[10px] font-medium transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-mood="calm"
                  >
                    Calm
                  </button>
                  <button
                    class="ai-mood-btn flex-1 px-2 py-1.5 rounded-lg text-[10px] font-medium transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-mood="warm"
                  >
                    Warm
                  </button>
                  <button
                    class="ai-mood-btn flex-1 px-2 py-1.5 rounded-lg text-[10px] font-medium transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-mood="tense"
                  >
                    Tense
                  </button>
                  <button
                    class="ai-mood-btn flex-1 px-2 py-1.5 rounded-lg text-[10px] font-medium transition-colors"
                    style="background: #2d2845; color: #c4b5fd; border: 1px solid #3b3556;"
                    data-mood="intense"
                  >
                    Intense
                  </button>
                </div>
              </div>
              <%!-- Apply --%>
              <button
                id="ai-settings-apply"
                class="w-full py-2 rounded-lg text-xs font-semibold transition-colors"
                style="background: #7c3aed; color: white;"
              >
                Apply &amp; Generate
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <%!-- /Right column --%>
</div>
<%!-- /Side-by-side wrapper --%>

<%!-- Guided Session: Follower floating badge --%>
<%= if @guided_session do %>
  <div class="fixed top-16 right-4 z-50">
    <div class="bg-base-200 rounded-full shadow-lg px-4 py-2 flex items-center gap-2 text-sm">
      <span class={[
        "w-2 h-2 rounded-full",
        if(@guided_presence.guide_connected, do: "bg-green-500", else: "bg-gray-400")
      ]}>
      </span>
      <%= if @guided_following do %>
        <span>Following guide</span>
        <button
          phx-click="follower_break_away"
          class="ml-1 text-xs text-base-content/50 hover:text-base-content underline"
        >
          Explore
        </button>
      <% else %>
        <span class="text-base-content/70">Exploring on your own</span>
        <button
          phx-click="follower_rejoin"
          class="ml-1 text-xs text-primary hover:text-primary-focus underline"
        >
          Return
        </button>
      <% end %>
      <button
        phx-click="guide_end_session"
        class="ml-2 text-xs text-error/60 hover:text-error"
        title="End session"
      >
        &times;
      </button>
    </div>
  </div>
<% end %>

<%!-- Guided Session: Follower suggestion toast --%>
<%= if @guided_suggestion do %>
  <div class="fixed bottom-24 left-1/2 -translate-x-1/2 z-50 max-w-md w-full px-4">
    <div class="bg-base-200 rounded-xl shadow-xl p-4 flex items-start gap-3">
      <div class="flex-1">
        <p class="text-sm font-medium">{@guided_suggestion.text}</p>
      </div>
      <button
        phx-click="dismiss_suggestion"
        class="text-base-content/40 hover:text-base-content text-lg leading-none"
      >
        &times;
      </button>
    </div>
  </div>
<% end %>

<%!-- Guided Session: Guide panel --%>
<%= if @guiding_session do %>
  <%!-- Mobile FAB (< sm) --%>
  <button
    :if={!@guide_panel_expanded}
    phx-click="toggle_guide_panel"
    class="fixed bottom-20 right-3 z-50 sm:hidden w-12 h-12 rounded-full bg-purple-600 hover:bg-purple-500 text-white shadow-lg flex items-center justify-center"
    title="Open guide controls"
  >
    <Heroicons.icon name="academic-cap" type="solid" class="h-6 w-6" />
  </button>

  <%!-- Panel: bottom sheet on mobile, side panel on sm+ --%>
  <div
    :if={@guide_panel_expanded}
    class={[
      "fixed z-50",
      "inset-x-0 bottom-0 sm:inset-x-auto sm:bottom-auto",
      "sm:top-16 sm:right-4"
    ]}
  >
    <%!-- Backdrop on mobile --%>
    <div
      class="fixed inset-0 bg-black/30 sm:hidden"
      phx-click="toggle_guide_panel"
    >
    </div>

    <div class={[
      "relative bg-gray-800 border border-gray-700 shadow-xl",
      "rounded-t-2xl sm:rounded-xl",
      "w-full sm:w-80",
      "max-h-[80vh] sm:max-h-[calc(100vh-5rem)]",
      "overflow-y-auto"
    ]}>
      <%!-- Drag handle (mobile) --%>
      <div class="flex justify-center pt-2 pb-1 sm:hidden">
        <div class="w-10 h-1 rounded-full bg-gray-600"></div>
      </div>

      <div class="p-2.5 sm:p-3">
        <%!-- Header --%>
        <div class="flex items-center justify-between mb-2.5">
          <div class="flex items-center gap-2">
            <Heroicons.icon name="academic-cap" type="solid" class="h-4 w-4 text-purple-400" />
            <span class="text-sm font-semibold text-white">Guiding</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="flex items-center gap-1.5">
              <span class={[
                "w-2 h-2 rounded-full",
                if(@guided_presence.follower_connected, do: "bg-green-500", else: "bg-gray-500")
              ]}>
              </span>
              <span class="text-[10px] sm:text-xs text-gray-400">
                {if @guided_following, do: "Following", else: "Exploring"}
              </span>
            </div>
            <button
              phx-click="toggle_guide_panel"
              class="p-1 rounded hover:bg-gray-700 text-gray-400 hover:text-white sm:hidden"
            >
              <Heroicons.icon name="x-mark" type="outline" class="h-4 w-4" />
            </button>
          </div>
        </div>

        <%!-- Lens Selector --%>
        <div class="mb-2.5">
          <p class="text-[10px] sm:text-xs text-gray-500 mb-1.5">Lens</p>
          <div class="flex flex-wrap gap-1">
            <button
              phx-click="guide_set_lens"
              phx-value-lens="sensors"
              class={"px-2 py-0.5 rounded-full text-[10px] sm:text-xs transition-colors " <>
                if(@live_action == :sensors,
                  do: "bg-purple-600 text-white",
                  else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                )}
            >
              All
            </button>
            <button
              phx-click="guide_set_lens"
              phx-value-lens="users"
              class={"px-2 py-0.5 rounded-full text-[10px] sm:text-xs transition-colors " <>
                if(@live_action == :users,
                  do: "bg-purple-600 text-white",
                  else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                )}
            >
              By Person
            </button>
            <%= for lens <- @available_lenses, lens not in [:sensors, :users, :hierarchy, :favorites] do %>
              <button
                phx-click="guide_set_lens"
                phx-value-lens={lens}
                class={"px-2 py-0.5 rounded-full text-[10px] sm:text-xs transition-colors " <>
                  if(@live_action == lens,
                    do: "bg-purple-600 text-white",
                    else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                  )}
              >
                {lens |> Atom.to_string() |> String.capitalize()}
              </button>
            <% end %>
            <button
              :if={:graph in @available_lenses}
              phx-click="guide_set_lens"
              phx-value-lens="graph"
              class={"px-2 py-0.5 rounded-full text-[10px] sm:text-xs transition-colors " <>
                if(@live_action == :graph,
                  do: "bg-purple-600 text-white",
                  else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                )}
            >
              Graph
            </button>
            <button
              :if={:graph3d in @available_lenses}
              phx-click="guide_set_lens"
              phx-value-lens="graph3d"
              class={"px-2 py-0.5 rounded-full text-[10px] sm:text-xs transition-colors " <>
                if(@live_action == :graph3d,
                  do: "bg-purple-600 text-white",
                  else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                )}
            >
              3D Graph
            </button>
          </div>
        </div>

        <%!-- Settings Row --%>
        <div class="mb-2.5 grid grid-cols-2 gap-2">
          <%!-- Layout --%>
          <div>
            <p class="text-[10px] sm:text-xs text-gray-500 mb-1">Layout</p>
            <div class="flex gap-1">
              <button
                phx-click="guide_set_layout"
                phx-value-layout="stacked"
                class={"p-1.5 rounded transition-colors " <>
                  if(@lobby_layout == :stacked,
                    do: "bg-purple-600 text-white",
                    else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                  )}
                title="Stacked layout"
              >
                <Heroicons.icon name="bars-3" type="outline" class="h-3.5 w-3.5" />
              </button>
              <button
                phx-click="guide_set_layout"
                phx-value-layout="side_by_side"
                class={"p-1.5 rounded transition-colors " <>
                  if(@lobby_layout == :side_by_side,
                    do: "bg-purple-600 text-white",
                    else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                  )}
                title="Side-by-side layout"
              >
                <Heroicons.icon name="view-columns" type="outline" class="h-3.5 w-3.5" />
              </button>
            </div>
          </div>

          <%!-- Sort --%>
          <div>
            <p class="text-[10px] sm:text-xs text-gray-500 mb-1">Sort</p>
            <div class="flex flex-wrap gap-1">
              <%= for {label, value} <- [{"Act", "activity"}, {"Name", "name"}, {"Type", "type"}, {"Bat", "battery"}] do %>
                <button
                  phx-click="guide_set_sort"
                  phx-value-sort_by={value}
                  class={"px-1.5 py-0.5 rounded text-[10px] transition-colors " <>
                    if(Atom.to_string(@sort_by) == value,
                      do: "bg-purple-600 text-white",
                      else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                    )}
                >
                  {label}
                </button>
              <% end %>
            </div>
          </div>
        </div>

        <%!-- Quality --%>
        <div class="mb-2.5">
          <p class="text-[10px] sm:text-xs text-gray-500 mb-1">Data Quality</p>
          <div class="flex flex-wrap gap-1">
            <button
              phx-click="guide_set_quality"
              phx-value-quality="auto"
              class={"px-1.5 py-0.5 rounded text-[10px] transition-colors " <>
                if(is_nil(@quality_override),
                  do: "bg-blue-600 text-white",
                  else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                )}
            >
              Auto
            </button>
            <button
              phx-click="guide_set_quality"
              phx-value-quality="high"
              class={"px-1.5 py-0.5 rounded text-[10px] transition-colors " <>
                if(@quality_override == :high,
                  do: "bg-green-600 text-white",
                  else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                )}
            >
              High
            </button>
            <button
              phx-click="guide_set_quality"
              phx-value-quality="medium"
              class={"px-1.5 py-0.5 rounded text-[10px] transition-colors " <>
                if(@quality_override == :medium,
                  do: "bg-yellow-600 text-white",
                  else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                )}
            >
              Med
            </button>
            <button
              phx-click="guide_set_quality"
              phx-value-quality="low"
              class={"px-1.5 py-0.5 rounded text-[10px] transition-colors " <>
                if(@quality_override == :low,
                  do: "bg-orange-600 text-white",
                  else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                )}
            >
              Low
            </button>
            <button
              phx-click="guide_set_quality"
              phx-value-quality="minimal"
              class={"px-1.5 py-0.5 rounded text-[10px] transition-colors " <>
                if(@quality_override == :minimal,
                  do: "bg-red-600 text-white",
                  else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                )}
            >
              Min
            </button>
          </div>
        </div>

        <%!-- Content Mode --%>
        <div class="mb-2.5">
          <p class="text-[10px] sm:text-xs text-gray-500 mb-1">Content</p>
          <div class="flex flex-wrap gap-1">
            <%= for {label, value} <- [{"Media", "media"}, {"3D", "object3d"}, {"Board", "whiteboard"}, {"Polls", "polls"}] do %>
              <button
                phx-click="guide_set_lobby_mode"
                phx-value-mode={value}
                class={"px-2 py-0.5 rounded text-[10px] sm:text-xs transition-colors " <>
                  if(Atom.to_string(@lobby_mode) == value,
                    do: "bg-purple-600 text-white",
                    else: "bg-gray-700 text-gray-300 hover:bg-gray-600"
                  )}
              >
                {label}
              </button>
            <% end %>
          </div>
        </div>

        <%!-- Suggestions --%>
        <div class="mb-2.5">
          <p class="text-[10px] sm:text-xs text-gray-500 mb-1">Suggestions</p>
          <div class="flex flex-wrap gap-1">
            <button
              phx-click="guide_suggest"
              phx-value-type="breathing_rhythm"
              phx-value-text="Try breathing at 6 breaths/min"
              class="px-2 py-0.5 rounded text-[10px] sm:text-xs bg-gray-700 text-gray-300 hover:bg-gray-600 transition-colors"
            >
              Breathing
            </button>
            <button
              phx-click="guide_suggest"
              phx-value-type="take_break"
              phx-value-text="Take a short break"
              class="px-2 py-0.5 rounded text-[10px] sm:text-xs bg-gray-700 text-gray-300 hover:bg-gray-600 transition-colors"
            >
              Break
            </button>
          </div>
        </div>

        <%!-- Actions --%>
        <div class="flex gap-1.5">
          <button
            phx-click="open_guide_share"
            class="flex-1 flex items-center justify-center gap-1 px-2 py-1.5 rounded-lg bg-purple-600/20 hover:bg-purple-600/40 text-purple-300 border border-purple-600/30 text-[10px] sm:text-xs transition-colors"
          >
            <Heroicons.icon name="share" type="outline" class="h-3 w-3" /> Share
          </button>
          <button
            phx-click="guide_end_session"
            class="flex-1 flex items-center justify-center gap-1 px-2 py-1.5 rounded-lg bg-red-600/20 hover:bg-red-600/40 text-red-400 border border-red-600/30 text-[10px] sm:text-xs transition-colors"
          >
            <Heroicons.icon name="x-circle" type="outline" class="h-3 w-3" /> End
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%!-- Guide Session Share Modal --%>
<%= if @show_guide_modal do %>
  <div
    class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-2 sm:p-4 md:p-6"
    phx-click="close_guide_modal"
  >
    <div
      class="bg-gray-800 rounded-lg p-3 sm:p-4 md:p-6 w-full max-w-sm sm:max-w-md max-h-[95vh] overflow-y-auto"
      phx-click={%JS{}}
    >
      <div class="flex justify-between items-center mb-3 sm:mb-4">
        <h2 class="text-base sm:text-lg md:text-xl font-semibold">Guided Session</h2>
        <button phx-click="close_guide_modal" class="text-gray-400 hover:text-white p-1 -mr-1">
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
        </button>
      </div>

      <%!-- Invite Code --%>
      <div class="text-center mb-3 sm:mb-4 p-3 bg-gray-700/50 rounded-lg">
        <p class="text-gray-400 text-xs sm:text-sm mb-1">Invite Code</p>
        <p class="text-xl sm:text-2xl md:text-3xl font-mono font-bold tracking-wider text-white">
          {@guide_invite_code}
        </p>
      </div>

      <%!-- Share Link --%>
      <div class="mb-3 sm:mb-4">
        <p class="text-gray-400 text-xs sm:text-sm mb-2">Share Link</p>
        <div class="flex gap-2">
          <input
            type="text"
            readonly
            value={@guide_share_url}
            class="flex-1 min-w-0 bg-gray-700 border border-gray-600 rounded-lg px-2 sm:px-3 py-2 text-white text-xs sm:text-sm truncate"
            id="guide-share-url-input"
          />
          <button
            phx-hook="CopyToClipboard"
            id="guide-copy-link-btn"
            data-copy-text={@guide_share_url}
            class="bg-blue-600 hover:bg-blue-700 text-white px-2 sm:px-3 py-2 rounded-lg transition-colors text-xs sm:text-sm whitespace-nowrap flex items-center gap-1"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"
              />
            </svg>
            <span class="hidden sm:inline">Copy</span>
          </button>
        </div>
      </div>

      <%!-- Share to Chat --%>
      <div class="mb-3 sm:mb-4">
        <button
          phx-click="share_guide_to_chat"
          class="w-full flex items-center justify-center gap-2 px-3 py-2.5 bg-purple-600/20 hover:bg-purple-600/40 text-purple-300 border border-purple-600/30 rounded-lg transition-colors text-sm font-medium"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
            />
          </svg>
          Share to Lobby Chat
        </button>
      </div>

      <%!-- Share via Apps --%>
      <% guide_share_text = "Join my guided session on Sensocto! Code: #{@guide_invite_code}" %>
      <% guide_encoded_url = URI.encode_www_form(@guide_share_url || "") %>
      <% guide_encoded_text = URI.encode_www_form(guide_share_text) %>
      <div class="mb-3 sm:mb-4">
        <p class="text-gray-400 text-xs sm:text-sm mb-2">Share via</p>
        <div class="grid grid-cols-4 sm:grid-cols-5 gap-2">
          <%!-- WhatsApp --%>
          <a
            href={"https://wa.me/?text=#{guide_encoded_text}%20#{guide_encoded_url}"}
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col items-center p-2 sm:p-3 bg-gray-700 hover:bg-green-600/20 rounded-lg transition-colors group"
            title="Share via WhatsApp"
          >
            <svg
              class="w-5 h-5 sm:w-6 sm:h-6 text-green-500 group-hover:text-green-400"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            <span class="text-[10px] sm:text-xs text-gray-400 mt-1">WhatsApp</span>
          </a>

          <%!-- Telegram --%>
          <a
            href={"https://t.me/share/url?url=#{guide_encoded_url}&text=#{guide_encoded_text}"}
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col items-center p-2 sm:p-3 bg-gray-700 hover:bg-blue-600/20 rounded-lg transition-colors group"
            title="Share via Telegram"
          >
            <svg
              class="w-5 h-5 sm:w-6 sm:h-6 text-blue-400 group-hover:text-blue-300"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" />
            </svg>
            <span class="text-[10px] sm:text-xs text-gray-400 mt-1">Telegram</span>
          </a>

          <%!-- SMS --%>
          <a
            href={"sms:?body=#{guide_encoded_text}%20#{guide_encoded_url}"}
            class="flex flex-col items-center p-2 sm:p-3 bg-gray-700 hover:bg-blue-600/20 rounded-lg transition-colors group"
            title="Share via SMS/Messages"
          >
            <svg
              class="w-5 h-5 sm:w-6 sm:h-6 text-blue-500 group-hover:text-blue-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
              />
            </svg>
            <span class="text-[10px] sm:text-xs text-gray-400 mt-1">SMS</span>
          </a>

          <%!-- Email --%>
          <a
            href={"mailto:?subject=#{URI.encode_www_form("Join my Sensocto guided session")}&body=#{guide_encoded_text}%0A%0A#{guide_encoded_url}"}
            class="flex flex-col items-center p-2 sm:p-3 bg-gray-700 hover:bg-purple-600/20 rounded-lg transition-colors group"
            title="Share via Email"
          >
            <svg
              class="w-5 h-5 sm:w-6 sm:h-6 text-purple-400 group-hover:text-purple-300"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              />
            </svg>
            <span class="text-[10px] sm:text-xs text-gray-400 mt-1">Email</span>
          </a>

          <%!-- Discord --%>
          <a
            href="https://discord.com/channels/@me"
            target="_blank"
            rel="noopener noreferrer"
            phx-hook="CopyToClipboard"
            id="guide-discord-share-btn"
            data-copy-text={"#{guide_share_text} #{@guide_share_url}"}
            class="flex flex-col items-center p-2 sm:p-3 bg-gray-700 hover:bg-indigo-600/20 rounded-lg transition-colors group cursor-pointer"
            title="Copy for Discord"
          >
            <svg
              class="w-5 h-5 sm:w-6 sm:h-6 text-indigo-400 group-hover:text-indigo-300"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z" />
            </svg>
            <span class="text-[10px] sm:text-xs text-gray-400 mt-1">Discord</span>
          </a>
        </div>
      </div>

      <%!-- QR Code --%>
      <div class="flex justify-center p-2 sm:p-3 bg-white rounded-lg">
        <div
          id="guide-qr-code"
          phx-hook="QRCode"
          data-value={@guide_share_url}
          class="w-28 h-28 sm:w-36 sm:h-36 md:w-44 md:h-44"
        >
        </div>
      </div>
      <p class="text-center text-gray-500 text-[10px] sm:text-xs mt-2">
        Scan QR code to join session
      </p>
    </div>
  </div>
<% end %>

<%!-- Join Room Modal --%>
<%= if @show_join_modal do %>
  <div
    class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
    phx-click="close_join_modal"
  >
    <div
      class="bg-gray-800 rounded-lg p-6 w-full max-w-md max-h-[80vh] overflow-y-auto"
      phx-click={%JS{}}
    >
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-xl font-semibold">Join a Room</h2>
        <button phx-click="close_join_modal" class="text-gray-300 hover:text-white">
          <Heroicons.icon name="x-mark" type="outline" class="h-6 w-6" />
        </button>
      </div>

      <%!-- Join by Code --%>
      <div class="mb-6">
        <label for="join_code" class="block text-sm font-medium text-gray-300 mb-2">
          Enter Room Code
        </label>
        <form phx-submit="join_room_by_code" class="flex gap-2">
          <input
            type="text"
            name="join_code"
            id="join_code"
            value={@join_code}
            phx-change="update_join_code"
            placeholder="ABCD1234"
            aria-describedby="join_code_help"
            class="flex-1 bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 text-white uppercase tracking-wider font-mono focus:outline-none focus:ring-2 focus:ring-blue-500"
            maxlength="12"
            autocomplete="off"
          />
          <button
            type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors"
          >
            Join
          </button>
        </form>
        <p id="join_code_help" class="text-xs text-gray-500 mt-1">
          Enter the room's join code to connect with your sensors
        </p>
      </div>

      <%!-- Public Rooms List --%>
      <%= if @public_rooms != [] do %>
        <div class="border-t border-gray-700 pt-4">
          <h3 class="text-sm font-medium text-gray-300 mb-3">Or join a public room</h3>
          <div class="space-y-2 max-h-60 overflow-y-auto">
            <%= for room <- @public_rooms do %>
              <div class="flex items-center justify-between p-3 bg-gray-700 rounded-lg hover:bg-gray-600 transition-colors">
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-white truncate">{room.name}</p>
                  <p :if={room.description} class="text-xs text-gray-300 truncate">
                    {room.description}
                  </p>
                </div>
                <button
                  phx-click="join_room"
                  phx-value-room_id={room.id}
                  class="ml-3 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-1.5 px-3 rounded transition-colors flex-shrink-0"
                >
                  Join
                </button>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="mt-6 pt-4 border-t border-gray-700">
        <.link
          navigate={~p"/rooms/new"}
          class="block w-full text-center bg-gray-700 hover:bg-gray-600 text-white font-semibold py-2 px-4 rounded-lg transition-colors"
        >
          Create New Room
        </.link>
      </div>
    </div>
  </div>
<% end %>

<%!-- Control Request Modal --%>
<%= if @control_request_modal do %>
  <div
    id="lobby-control-request-modal"
    phx-hook="NotificationSound"
    class="fixed inset-0 z-[100] flex items-center justify-center bg-black/70 backdrop-blur-sm"
  >
    <div class="bg-gray-800 rounded-xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-700">
      <%!-- Header --%>
      <div class="bg-gradient-to-r from-cyan-600 to-blue-600 px-6 py-4">
        <div class="flex items-center gap-3">
          <div class="p-2 bg-white/20 rounded-full">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
              />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-white">Control Request</h2>
        </div>
      </div>

      <%!-- Content --%>
      <div class="p-6">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-14 h-14 bg-gray-700 rounded-full flex items-center justify-center">
            <svg
              class="w-8 h-8 text-gray-300"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
              />
            </svg>
          </div>
          <div>
            <p class="text-lg font-semibold text-white">
              {@control_request_modal.requester_name}
            </p>
            <p class="text-sm text-gray-300">
              wants to control the 3D viewer
            </p>
          </div>
        </div>

        <p class="text-gray-300 text-sm mb-4">
          Transferring control will allow them to navigate the 3D scene while you follow their view.
        </p>

        <%!-- Auto-transfer warning with countdown --%>
        <div
          id="object3d-control-countdown"
          phx-hook="CountdownTimer"
          role="timer"
          aria-live="polite"
          aria-atomic="true"
          data-seconds="30"
          class="mb-6 p-3 bg-amber-900/30 border border-amber-600/50 rounded-lg"
        >
          <p class="text-amber-200 text-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            Control will auto-transfer in <span class="font-bold countdown-display">30</span>s
          </p>
        </div>

        <%!-- Actions --%>
        <div class="flex gap-3">
          <button
            phx-click="dismiss_control_request"
            class="flex-1 px-4 py-3 bg-gray-700 hover:bg-gray-600 text-white font-medium rounded-lg transition-colors"
          >
            Keep Control
          </button>
          <button
            phx-click="release_control_from_modal"
            class="flex-1 px-4 py-3 bg-cyan-600 hover:bg-cyan-500 text-white font-medium rounded-lg transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
              />
            </svg>
            Transfer Control
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%!-- Media Control Request Modal --%>
<%= if @media_control_request_modal do %>
  <div
    id="lobby-media-control-request-modal"
    phx-hook="NotificationSound"
    class="fixed inset-0 z-[100] flex items-center justify-center bg-black/70 backdrop-blur-sm"
  >
    <div class="bg-gray-800 rounded-xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-700">
      <%!-- Header --%>
      <div class="bg-gradient-to-r from-red-600 to-orange-600 px-6 py-4">
        <div class="flex items-center gap-3">
          <div class="p-2 bg-white/20 rounded-full">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-white">Media Control Request</h2>
        </div>
      </div>

      <%!-- Content --%>
      <div class="p-6">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-14 h-14 bg-gray-700 rounded-full flex items-center justify-center">
            <svg
              class="w-8 h-8 text-gray-300"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
              />
            </svg>
          </div>
          <div>
            <p class="text-lg font-semibold text-white">
              {@media_control_request_modal.requester_name}
            </p>
            <p class="text-sm text-gray-300">
              wants to control the media player
            </p>
          </div>
        </div>

        <p class="text-gray-300 text-sm mb-4">
          Transferring control will allow them to play, pause, and navigate the media playlist.
        </p>

        <%!-- Auto-transfer warning with countdown --%>
        <div
          id="media-control-countdown"
          phx-hook="CountdownTimer"
          role="timer"
          aria-live="polite"
          aria-atomic="true"
          data-seconds="30"
          class="mb-6 p-3 bg-amber-900/30 border border-amber-600/50 rounded-lg"
        >
          <p class="text-amber-200 text-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            Control will auto-transfer in <span class="font-bold countdown-display">30</span>s
          </p>
        </div>

        <%!-- Actions --%>
        <div class="flex gap-3">
          <button
            phx-click="dismiss_media_control_request"
            class="flex-1 px-4 py-3 bg-gray-700 hover:bg-gray-600 text-white font-medium rounded-lg transition-colors"
          >
            Keep Control
          </button>
          <button
            phx-click="release_media_control_from_modal"
            class="flex-1 px-4 py-3 bg-red-600 hover:bg-red-500 text-white font-medium rounded-lg transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
              />
            </svg>
            Transfer Control
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>
